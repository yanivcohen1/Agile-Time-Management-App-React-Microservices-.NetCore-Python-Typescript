{
  "name": "agile-app-react-py-cs",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "cd ./client && pnpm dev",
    "build": "cd ./client && pnpm build",
    "preview": "cd ./client && pnpm preview",
    "lint": "cd ./client && pnpm lint",
    "audit": "cd ./client && pnpm audit",
    "test": "cd ./client && pnpm test",
    "test:watch": "cd ./client && pnpm test:watch",
    "coverage": "cd ./client && pnpm coverage",
    "test:e2e": "cd ./client && pnpm test:e2e",
    "test:e2e:report": "cd ./client && pnpm test:e2e:report",
    "test:e2e:ui": "cd ./client && pnpm test:e2e:ui",

    "test:py": "cd ./backend_python_service && .venv\\Scripts\\python -m pytest",
    "lint:py": "cd ./backend_python_service && .venv\\Scripts\\python -m mypy app",
    "seed:py": "cd ./backend_python_service && .venv\\Scripts\\python seed.py",
    "serve:py": "cd ./backend_python_service && .venv\\Scripts\\python -m uvicorn app.main:app --reload --port 5000",
    "serve:py:prod": "cd ./backend_python_service && cross-env ENV=prod .venv\\Scripts\\python -m uvicorn app.main:app --port 5000",
    "activate:py": "cd ./backend_python_service && .venv\\Scripts\\activate",

    "seed:cs": "cd ./backend_netCore_service/AuthApi && dotnet run -- --seed",
    "test:cs": "cd ./backend_netCore_service/AuthApi && dotnet test",
    "lint:cs": "cd ./backend_netCore_service/AuthApi && dotnet format",
    "serve:cs": "cd ./backend_netCore_service/AuthApi && dotnet run",
    "serve:cs:prod": "cd ./backend_netCore_service/AuthApi && dotnet run -- --env prod",

    "seed:ts": "cd ./backend_typescript_service && pnpm seed:db",
    "test:ts": "cd ./backend_typescript_service && pnpm test",
    "lint:ts": "cd ./backend_typescript_service && pnpm lint",
    "serve:ts": "cd ./backend_typescript_service && pnpm dev",
    "tsoa:ts": "cd ./backend_typescript_service && pnpm tsoa",
    "build:ts": "cd ./backend_typescript_service && pnpm build",
    "serve:ts:prod": "cd ./backend_typescript_service && pnpm start",
    "audit:ts": "cd ./backend_typescript_service && pnpm audit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.22.0"
}
