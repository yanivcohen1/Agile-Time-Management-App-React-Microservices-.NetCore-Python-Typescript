{
  "name": "express-ts-app",
  "version": "1.0.0",
  "description": "Express server with TypeScript for user authorization route",
  "main": "dist/server.js",
  "scripts": {
    "audit": "pnpm audit",
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only src/server.ts",
    "tsoa": "tsoa spec-and-routes",
    "build": "pnpm tsoa && tsc -p tsconfig.build.json",
    "start": "cross-env NODE_ENV=production node dist/server.js",
    "seed:db": "cross-env NODE_ENV=development ts-node create-users.ts",
    "lint": "tsc --noEmit && eslint src tests --ext .ts --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mikro-orm/core": "^5.9.8",
    "@mikro-orm/migrations-mongodb": "^5.9.8",
    "@mikro-orm/mongodb": "^5.9.8",
    "@mikro-orm/reflection": "^5.9.8",
    "@tsoa/runtime": "7.0.0-alpha.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^7.2.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "5.8.1",
    "multer": "^2.1.1",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "7.0.0-alpha.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^5.9.8",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongodb": "^3.6.20",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/supertest": "^2.0.16",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "mongodb-memory-server": "^10.4.3",
    "rimraf": "^6.1.3",
    "supertest": "^6.3.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.5.4",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "ajv": ">=8.18.0"
    }
  }
}
